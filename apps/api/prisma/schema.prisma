generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum MemberRole {
  OWNER
  ADMIN
  DEVELOPER
  VIEWER
}

enum GitProvider {
  GITHUB
  GITLAB
  BITBUCKET
}

enum ProviderConnectionStatus {
  ACTIVE
  SUSPENDED
  DISCONNECTED
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  fullName     String?
  status       UserStatus @default(ACTIVE)

  memberships         Membership[]
  sessions            Session[]
  providerConnections ProviderConnection[] @relation("ProviderConnectionCreator")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Organization {
  id   String @id @default(uuid())
  name String
  slug String @unique

  workspaces          Workspace[]
  memberships         Membership[]
  providerConnections ProviderConnection[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Workspace {
  id             String @id @default(uuid())
  name           String
  slug           String
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repositories Repository[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Repository {
  id                   String      @id @default(uuid())
  name                 String
  fullName             String
  provider             GitProvider
  externalId           String?
  defaultBranch        String?
  url                  String?
  isPrivate            Boolean?
  workspaceId          String
  providerConnectionId String?

  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  providerConnection ProviderConnection? @relation(fields: [providerConnectionId], references: [id], onDelete: SetNull)

  branches RepositoryBranch[]
  commits  RepositoryCommit[]
  files    RepositoryFile[]
  chunks   RepositoryChunk[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, fullName])
  @@index([workspaceId])
  @@index([providerConnectionId])
}

model RepositoryBranch {
  id           String  @id @default(uuid())
  repositoryId String
  name         String
  sha          String?
  isDefault    Boolean @default(false)

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([repositoryId, name])
  @@index([repositoryId])
}

model RepositoryCommit {
  id           String    @id @default(uuid())
  repositoryId String
  sha          String
  message      String?
  authorName   String?
  authorEmail  String?
  committedAt  DateTime?
  url          String?

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([repositoryId, sha])
  @@index([repositoryId])
  @@index([sha])
}

model RepositoryFile {
  id           String  @id @default(uuid())
  repositoryId String
  path         String
  sha          String
  size         Int
  language     String?
  content      String  @db.Text

  repository Repository        @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  chunks     RepositoryChunk[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastSyncedAt DateTime @default(now())

  @@unique([repositoryId, path])
  @@index([repositoryId])
  @@index([repositoryId, language])
}

model RepositoryChunk {
  id             String    @id @default(uuid())
  repositoryId   String
  fileId         String
  chunkIndex     Int
  startLine      Int
  endLine        Int
  language       String?
  sourceSha      String
  contentHash    String
  content        String    @db.Text
  embedding      Float[]   @default([])
  embeddingModel String?
  embeddedAt     DateTime?

  repository Repository     @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  file       RepositoryFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fileId, chunkIndex])
  @@index([repositoryId])
  @@index([fileId])
  @@index([repositoryId, language])
  @@index([contentHash])
}

model ProviderConnection {
  id                String                   @id @default(uuid())
  organizationId    String
  connectedByUserId String
  provider          GitProvider
  externalAccountId String
  accountLogin      String
  installationId    String?                  @unique
  status            ProviderConnectionStatus @default(ACTIVE)
  disconnectedAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connectedBy  User         @relation("ProviderConnectionCreator", fields: [connectedByUserId], references: [id], onDelete: Restrict)
  repositories Repository[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, provider, externalAccountId])
  @@index([organizationId])
  @@index([connectedByUserId])
}

model Membership {
  id             String     @id @default(uuid())
  userId         String
  organizationId String
  role           MemberRole @default(DEVELOPER)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Session {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
